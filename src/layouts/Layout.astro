---
import Music from '../components/Music.astro'
---

<!doctype html>
<html lang='es'>
  <head>
    <meta charset='UTF-8' />
    <title>Paulina - Quince Años</title>
    <meta property='og:title' content='Paulina - Quince Años' />
    <meta property='og:image' content='/og.jpeg' />
    <meta
      name='viewport'
      content='width=device-width, initial-scale=1.0'
    />
    <link
      rel='favicon'
      href='/favicon.ico'
      type='image/icon'
    />
  </head>
  <body class='select-none bg-tertiary'>
    <div id='parallax'></div>
    <div class='relative mx-auto min-h-screen max-w-[550px] bg-tertiary'>
      <div class='relative sticky top-0 z-10 h-0'>
        <div class='absolute right-4 top-4'>
          <Music src='/music/music.mp3' />
        </div>
      </div>
      <slot />
    </div>
  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Yustine Signature';
    src: url('/fonts/Yustine Signature.otf') format('opentype');
  }

  @font-face {
    font-family: 'Athelas';
    src: url('/fonts/Athelas-Regular.ttf') format('truetype');
    font-weight: 400;
  }

  @font-face {
    font-family: 'Athelas';
    src: url('/fonts/Athelas-Bold.ttf') format('truetype');
    font-weight: 600;
  }

  :root {
    font-size: 16px;
  }

  html {
    font-family: 'Athelas', sans-serif;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  #parallax {
    position: fixed;
    top: -30vh;
    left: 0;
    width: 100%;
    height: 160vh;

    background-image: url('/background.jpeg');
    background-size: cover;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;

    z-index: -1;
  }
</style>

<script type='js' is:inline>
  const bg = document.getElementById('parallax')

  window.addEventListener('scroll', () => {
    bg.style.transform = `translate3d(0, -${window.scrollY * 0.1}px, 0)`
  })
</script>
