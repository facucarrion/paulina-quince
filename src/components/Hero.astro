---
---

<section class='relative flex h-screen flex-col items-center justify-center'>
  <img src='/logo.webp' alt='Logo' class='absolute top-1/3 w-80 -translate-y-1/2' />
  <div class='absolute top-[65%] flex flex-col items-center gap-4'>
    <div
      class='flex items-start gap-3 text-3xl font-semibold tracking-wide text-white max-sm:gap-2 max-sm:text-2xl'
      id='countdown'
    ></div>
  </div>
</section>

<style>
  section {
    background-image: url('/portada.webp');
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
  }

  @media (max-width: 640px) {
    section {
      background-position: 52% center;
    }
  }
</style>

<script>
  const countdown = document.getElementById('countdown') as HTMLDivElement
  const goalDate = new Date('2026-09-26T21:30:00').getTime()

  function updateCountdown() {
    const actualDate = new Date().getTime()
    const difference = goalDate - actualDate

    const data = {
      days: Math.floor(difference / (1000 * 60 * 60 * 24)),
      hours: Math.floor(
        (difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60)
      ),
      minutes: Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60)),
      seconds: Math.floor((difference % (1000 * 60)) / 1000)
    }

    if (difference >= 0) {
      const units = [
        { value: data.days, label: 'D\u00cdAS' },
        { value: data.hours, label: 'HORAS' },
        { value: data.minutes, label: 'MINUTOS' },
        { value: data.seconds, label: 'SEGUNDOS' }
      ]

      countdown.innerHTML = units
        .map(
          (unit, i) =>
            `<div class='flex flex-col items-center gap-6'>
              <span class='text-5xl max-sm:text-4xl'>${String(unit.value).padStart(2, '0')}</span>
              <span class='text-sm font-thin max-sm:text-xs'>${unit.label}</span>
            </div>${
              i < units.length - 1
                ? `<span class='mt-2 text-3xl'>:</span>`
                : ''
            }`
        )
        .join('')

      requestAnimationFrame(updateCountdown)
    } else {
      countdown.innerHTML = '\u00a1Es el d\u00eda!'
    }
  }

  updateCountdown()
</script>
